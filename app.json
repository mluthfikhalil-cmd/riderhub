{
  "expo": {
    "name": "RiderHub",
    "slug": "riderhub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "riderhub",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.riderhub.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.riderhub.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "backgroundColor": "#0D0D0D",
      "meta": {
        "title": "RiderHub - All-in-One App untuk Pemotor Indonesia",
        "description": "Marketplace spareparts, event touring, komunitas rider, dan fitur lengkap untuk pemotor Indonesia.",
        "ogImage": "./assets/icon.png"
      }
    },
    "plugins": [],
    "extra": {
      "eas": {
        "projectId": "riderhub-app"
      }
    }
  }
}